---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import MetricCard from '../../components/MetricCard.astro';
import SystemToggle from '../../components/SystemToggle.astro';
import { caseStudies } from '../../data/caseStudies';

export function getStaticPaths() {
  return caseStudies.map((study) => ({
    params: { slug: study.slug },
    props: { study },
  }));
}

const { study } = Astro.props;
---

<BaseLayout title={`${study.title} | Sanjeev Prasad`} description={study.description}>
  <Header />

  <main class="mx-auto max-w-[980px] px-5 py-16">
    <a class="text-sm font-extrabold text-mint no-underline hover:text-white" href="/#case-studies">
      Back to case studies
    </a>

    <header class="mt-8">
      {study.system && <p class="mb-4 text-xs font-extrabold uppercase tracking-wider text-mint">{study.system}</p>}
      <div class="flex flex-wrap gap-2">
        {study.tags.map((tag) => (
          <span class="rounded-full border border-white/15 bg-white/10 px-3 py-1 text-sm text-zinc-200">{tag}</span>
        ))}
      </div>
      <h1 class="mt-6 text-[clamp(2.6rem,7vw,5rem)] font-extrabold leading-none tracking-normal">
        {study.title}
      </h1>
      <p class="mt-6 max-w-3xl text-xl leading-8 text-zinc-300">{study.summary}</p>
    </header>

    <section class="mt-10">
      <MetricCard value={study.metric.value} label={study.metric.label} />
    </section>

    {study.interactive === 'backend-rewrite' && <SystemToggle title="Backend architecture change" />}

    <article class="mt-10 space-y-12">
      <section>
        <h2 class="text-3xl font-extrabold leading-tight text-white">Context</h2>
        <div class="mt-4 space-y-4">
          {study.context.map((paragraph) => <p class="text-lg leading-8 text-zinc-300">{paragraph}</p>)}
        </div>
      </section>

      <section>
        <h2 class="text-3xl font-extrabold leading-tight text-white">Problem</h2>
        <ul class="mt-4 list-disc space-y-2 pl-6 text-lg leading-8 text-zinc-300">
          {study.problem.map((item) => <li>{item}</li>)}
        </ul>
      </section>

      <section>
        <h2 class="text-3xl font-extrabold leading-tight text-white">Approach</h2>
        <ul class="mt-4 list-disc space-y-2 pl-6 text-lg leading-8 text-zinc-300">
          {study.approach.map((item) => <li>{item}</li>)}
        </ul>
      </section>

      <section>
        <h2 class="text-3xl font-extrabold leading-tight text-white">Outcome</h2>
        <ul class="mt-4 list-disc space-y-2 pl-6 text-lg leading-8 text-zinc-300">
          {study.outcome.map((item) => <li>{item}</li>)}
        </ul>
      </section>

      {study.note && (
        <section class="rounded-lg border border-white/15 bg-white/[0.08] p-6">
          <h2 class="text-2xl font-extrabold leading-tight text-white">Why It Matters</h2>
          <p class="mt-4 text-lg leading-8 text-zinc-300">{study.note}</p>
        </section>
      )}
    </article>
  </main>
</BaseLayout>
