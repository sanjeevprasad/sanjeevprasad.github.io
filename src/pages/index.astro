---
import { ArrowRight, ExternalLink } from '@lucide/astro';
import { Icon } from 'astro-icon/components';
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import CapabilityMap from '../components/CapabilityMap.astro';
import CaseStudyCard from '../components/CaseStudyCard.astro';
import ContactButton from '../components/ContactButton.astro';
import ObfuscatedExternalLink from '../components/ObfuscatedExternalLink.astro';
import { caseStudies } from '../data/caseStudies';

const sortedCaseStudies = [...caseStudies].sort((left, right) => {
  return left.order - right.order;
});

const focusAreas = [
  [
    'Rust Backend Engineering',
    'Build high-performance APIs, async services, WebSocket systems, telemetry ingestion, and backend rewrites.',
  ],
  [
    'Embedded Linux & Edge Devices',
    'Bring up boards, optimize boot paths, integrate modems, build framebuffer UIs, and support OTA paths.',
  ],
  [
    'Edge & Platform Architecture',
    'Design device-to-cloud systems across telemetry, dashboards, alerts, reporting, deployments, and operations.',
  ],
  [
    'Technical Review & Rescue',
    'Review architecture, isolate performance bottlenecks, reduce operational risk, and help teams recover stuck systems.',
  ],
];

const targetRoles = [
  'Senior Rust backend engineering',
  'Embedded Linux / edge systems',
  'Production systems and platform engineering',
  'Systems architecture and reliability consulting',
];
---

<BaseLayout
  title="Sanjeev Prasad | Rust, Embedded Linux & Production Systems Engineer"
  description="Rust, embedded Linux, edge platforms, and production systems engineer available for senior engineering roles and focused consulting."
>
  <Header />

  <main id="top" class="mx-auto max-w-[1180px] px-5">
    <section class="grid min-h-[calc(100vh-72px)] items-center gap-10 py-16 lg:grid-cols-[1.12fr_0.88fr] lg:gap-16">
      <div class="max-w-3xl">
        <p class="mb-3 text-xs font-extrabold uppercase tracking-wider text-mint">
          Rust, Embedded Linux & Production Systems Engineer
        </p>
        <h1 class="max-w-5xl text-[clamp(2.7rem,8vw,5.9rem)] font-extrabold leading-[0.96] tracking-normal">
          Production software from embedded Linux to Rust backends.
        </h1>
        <p class="mt-6 max-w-2xl text-lg leading-8 text-zinc-300 sm:text-xl">
          10 years building firmware, Linux devices, Rust services, telemetry pipelines, dashboards, alerts,
          and deployment systems. Available for senior engineering roles and focused consulting engagements.
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <ContactButton label="Discuss a role or project" />
          <a
            class="inline-flex min-h-12 items-center justify-center rounded-md border border-white/15 bg-white/10 px-5 py-3 font-extrabold text-white no-underline transition hover:-translate-y-px"
            href="#case-studies"
          >
            <ArrowRight class="mr-2 h-4 w-4" aria-hidden="true" />
            View case studies
          </a>
        </div>
      </div>

      <CapabilityMap />
    </section>

    <section id="case-studies" class="pt-20">
      <div class="mb-8 max-w-3xl">
        <p class="mb-3 text-xs font-extrabold uppercase tracking-wider text-mint">Case Studies</p>
        <h2 class="text-[clamp(2rem,4vw,3.45rem)] font-extrabold leading-tight tracking-normal">
          Proof from production systems
        </h2>
        <p class="mt-4 text-lg text-zinc-300">
          Selected work across embedded Linux, cellular connectivity, telemetry ingestion,
          Rust backends, dashboards, reports, alerts, and production operations.
        </p>
      </div>

      <div class="grid gap-5">
        {sortedCaseStudies.map((study) => (
          <CaseStudyCard
            title={study.title}
            summary={study.summary}
            system={study.system}
            slug={study.slug}
            tags={study.tags}
            featured={study.featured}
          />
        ))}
      </div>
    </section>

    <section id="focus" class="pt-24">
      <div class="mb-8 max-w-3xl">
        <p class="mb-3 text-xs font-extrabold uppercase tracking-wider text-mint">How I Can Help</p>
        <h2 class="text-[clamp(2rem,4vw,3.45rem)] font-extrabold leading-tight tracking-normal">
          Senior engineering capacity for difficult systems work
        </h2>
        <p class="mt-4 text-lg text-zinc-300">
          Useful for teams hiring a senior engineer, evaluating a consulting engagement, or needing focused help on
          reliability-critical software.
        </p>
      </div>
      <div class="grid gap-5 md:grid-cols-2">
        {focusAreas.map(([title, copy]) => (
          <div class="rounded-lg border border-white/15 bg-white/10 p-6">
            <h3 class="mb-3 text-xl font-extrabold">{title}</h3>
            <p class="text-zinc-300">{copy}</p>
          </div>
        ))}
      </div>
    </section>

    <section class="pt-24">
      <div class="grid gap-8 rounded-lg border border-white/15 bg-white/[0.08] p-6 md:grid-cols-[0.9fr_1.1fr] md:p-8">
        <div>
          <p class="mb-3 text-xs font-extrabold uppercase tracking-wider text-mint">Looking For</p>
          <h2 class="text-3xl font-extrabold leading-tight">Roles and consulting work where systems depth matters</h2>
        </div>
        <ul class="grid gap-3 p-0 sm:grid-cols-2">
          {targetRoles.map((role) => (
            <li class="list-none rounded-md border border-white/15 bg-black/20 px-4 py-3 font-extrabold text-zinc-100">
              {role}
            </li>
          ))}
        </ul>
      </div>
    </section>

    <section id="projects" class="pt-24">
      <div class="mb-8 max-w-3xl">
        <p class="mb-3 text-xs font-extrabold uppercase tracking-wider text-mint">Projects</p>
        <h2 class="text-[clamp(2rem,4vw,3.45rem)] font-extrabold leading-tight tracking-normal">Personal tools</h2>
        <p class="mt-4 text-lg text-zinc-300">
          Small utilities and experiments built to solve practical problems.
        </p>
      </div>

      <article class="rounded-lg border border-white/15 bg-white/[0.08] p-6 shadow-xl md:p-8">
        <div class="flex flex-wrap items-start justify-between gap-4">
          <div class="max-w-3xl">
            <p class="mb-3 text-xs font-extrabold uppercase tracking-wider text-mint">Svelte / Tailwind / Monaco</p>
            <h3 class="text-2xl font-extrabold leading-tight">Resume Builder</h3>
            <p class="mt-4 text-zinc-300">
              A browser-only JSON resume builder for quickly editing, previewing, and printing a resume without
              uploading data to a server.
            </p>
          </div>
          <div class="flex flex-wrap gap-3">
            <a
              class="inline-flex min-h-11 items-center justify-center rounded-md border border-mint/70 bg-mint px-4 py-2 font-extrabold text-ink no-underline transition hover:-translate-y-px"
              href="/resume-builder/"
            >
              <ExternalLink class="mr-2 h-4 w-4" aria-hidden="true" />
              Open
            </a>
            <a
              class="inline-flex min-h-11 items-center justify-center rounded-md border border-white/15 bg-white/10 px-4 py-2 font-extrabold text-white no-underline transition hover:-translate-y-px"
              href="https://github.com/sanjeevprasad/resume-builder"
            >
              <Icon name="simple-icons:github" class="mr-2 h-4 w-4" aria-hidden="true" />
              GitHub
            </a>
          </div>
        </div>
      </article>
    </section>

    <section id="contact" class="my-24 grid items-center gap-8 rounded-lg border border-white/15 bg-zinc-100 p-6 text-zinc-950 md:grid-cols-[1fr_auto] md:p-10">
      <div>
        <p class="mb-3 text-xs font-extrabold uppercase tracking-wider text-zinc-950">Contact</p>
        <h2 class="text-[clamp(2rem,4vw,3.45rem)] font-extrabold leading-tight tracking-normal">
          Have a role or technical problem worth discussing?
        </h2>
        <p class="mt-3 text-zinc-600">
          Send a short note about the role, system, bottleneck, or consulting engagement you have in mind.
        </p>
      </div>
      <div class="flex flex-wrap gap-3">
        <ContactButton label="Start a conversation" />
        <a
          class="inline-flex min-h-12 items-center justify-center rounded-md border border-zinc-950/20 bg-transparent px-5 py-3 font-extrabold text-zinc-950 no-underline transition hover:-translate-y-px"
          href="https://github.com/sanjeevprasad"
        >
          <Icon name="simple-icons:github" class="mr-2 h-4 w-4" aria-hidden="true" />
          GitHub
        </a>
        <ObfuscatedExternalLink
          label="LinkedIn"
          icon="simple-icons:linkedin"
          class="inline-flex min-h-12 items-center justify-center rounded-md border border-zinc-950/20 bg-transparent px-5 py-3 font-extrabold text-zinc-950 transition hover:-translate-y-px"
          codes={[
            111, 123, 123, 119, 122, 65, 54, 54, 126, 126, 126, 53, 115, 112, 117, 114, 108, 107,
            112, 117, 53, 106, 118, 116, 54, 112, 117, 54, 122, 104, 117, 113, 108, 108, 125, 119,
            121, 104, 122, 104, 107, 123, 111, 104, 114, 124, 121, 54,
          ]}
        />
      </div>
    </section>
  </main>
</BaseLayout>
